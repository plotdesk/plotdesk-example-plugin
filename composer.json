{
    "name": "plotdesk/plotdesk-example-plugin",
    "description": "plotdesk reference plugin showcasing the full Plugin SDK: apps, AI functions, custom pages, custom interfaces, events, permissions and rich chat payloads.",
    "type": "plotdesk-plugin",
    "license": "proprietary",
    "keywords": ["plotdesk", "plugin", "example", "reference"],
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "plotdesk/plugin-sdk": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "PlotdeskExamplePlugin\\": "src/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../../../packages/plugin-sdk",
            "options": {
                "symlink": false
            }
        }
    ],
    "config": {
        "sort-packages": true,
        "preferred-install": "dist"
    },
    "minimum-stability": "stable"
}
